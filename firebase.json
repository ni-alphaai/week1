{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [{ "source": "**", "destination": "/index.html" }]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20",
    "predeploy": [
      "node \"$RESOURCE_DIR/node_modules/typescript/lib/tsc.js\" -p \"$RESOURCE_DIR/tsconfig.json\""
    ]
  }
}
