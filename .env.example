# Copy to .env and fill in from your Firebase Web App config.
# Without these, the app runs in local-only mode (no cloud sync / auth).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Phase 2 AI (optional). All OFF unless set to "true"; the MVP runs fully without them.
# "Explain my mistake" uses Firebase AI Logic (Gemini) and requires Firebase above.
VITE_AI_ENABLED=
VITE_AI_EXPLAIN_ENABLED=
# P1: verified AI problem generation and adaptive difficulty (both optional).
VITE_AI_GENERATION_ENABLED=
VITE_AI_ADAPTIVE_ENABLED=
# AI provider: "gemini" (default, runs in-browser) or "openai" (via Cloud Function).
VITE_AI_PROVIDER=
# Gemini model (default: gemini-2.5-flash)
VITE_AI_MODEL=
# OpenAI model used by the Cloud Function proxy (default: gpt-5.4-mini).
VITE_AI_OPENAI_MODEL=
# Stronger OpenAI model for escalation after cheap attempts fail (default: gpt-5.4).
VITE_AI_OPENAI_STRONG_MODEL=
# NOTE: the OpenAI API key is NOT set here. It must never reach the browser.
# Store it as a Firebase secret: `firebase functions:secrets:set OPENAI_API_KEY`.
# Optional reCAPTCHA v3 site key to protect the AI endpoint with App Check.
VITE_RECAPTCHA_SITE_KEY=
